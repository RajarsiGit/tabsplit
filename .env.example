# Neon Postgres connection string
# Get this from your Neon console: https://console.neon.tech
# Format: postgres://[user]:[password]@[neon_hostname]/[database]?sslmode=require
DATABASE_URL=

# Secret used to sign JWTs - use a long random string in production
JWT_SECRET=

# Optional cron protection: Vercel sets this automatically for scheduled Cron Jobs
CRON_SECRET=

# GitHub OAuth App credentials, for "Continue with GitHub" login
# Create one at https://github.com/settings/developers
# Authorization callback URL must be: <your-app-url>/api/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
